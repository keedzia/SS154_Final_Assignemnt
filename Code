# OLS Linear Probability Model
ols_model <- lm(lethal ~ bwc + factor(year) + factor(race) + age +
                  factor(gender) + signs_of_mental_illness +
                  factor(threat_level) + factor(flee) +
                  factor(armed) + factor(state),
                data = df_iv)

summary(ols_model)

# OLS Key Variables Table
ols_coefs <- summary(ols_model)$coefficients

ols_key_vars <- c("bwc",
                  "factor(year)2016", "factor(year)2017", "factor(year)2018",
                  "factor(year)2019", "factor(year)2020", "factor(year)2021",
                  "factor(year)2022",
                  "factor(race)B", "factor(race)H", "factor(race)N",
                  "factor(race)O", "factor(race)W",
                  "age", "factor(gender)M",
                  "signs_of_mental_illnessTRUE",
                  "factor(threat_level)other", "factor(threat_level)undetermined",
                  "factor(flee)Foot", "factor(flee)Not fleeing", "factor(flee)Other")

ols_table <- as.data.frame(ols_coefs[ols_key_vars, ])
ols_table <- ols_table %>%
  mutate(
    Estimate     = round(Estimate, 4),
    `Std. Error` = round(`Std. Error`, 4),
    `t value`    = round(`t value`, 3),
    `Pr(>|t|)`   = round(`Pr(>|t|)`, 4),
    Significance = case_when(
      `Pr(>|t|)` < 0.001 ~ "***",
      `Pr(>|t|)` < 0.01  ~ "**",
      `Pr(>|t|)` < 0.05  ~ "*",
      `Pr(>|t|)` < 0.1   ~ ".",
      TRUE               ~ ""
    )
  )

rownames(ols_table) <- c(
  "BWC Present",
  "Year 2016", "Year 2017", "Year 2018", "Year 2019",
  "Year 2020", "Year 2021", "Year 2022",
  "Race: Black", "Race: Hispanic", "Race: Native American",
  "Race: Other", "Race: White",
  "Age", "Gender: Male", "Signs of Mental Illness",
  "Threat Level: Other", "Threat Level: Undetermined",
  "Flee: Foot", "Flee: Not Fleeing", "Flee: Other"
)

kable(ols_table,
      caption = "Table 4: Robustness Check - OLS Linear Probability Model (Key Variables)",
      format = "simple",
      col.names = c("Coef.", "Std. Err.", "t", "p-value", "Sig."))

# Logistic Regression Without State Fixed Effects
logit_no_state <- glm(lethal ~ bwc + factor(year) + factor(race) + age +
                        factor(gender) + signs_of_mental_illness +
                        factor(threat_level) + factor(flee) +
                        factor(armed),
                      data = df_iv, family = "binomial")

summary(logit_no_state)

# BWC Coefficient Comparison Across Models
comparison_table <- data.frame(
  Model = c("Logistic Regression (full)",
            "Logistic Regression (no state FE)",
            "OLS / LPM",
            "IV (2SLS)"),
  BWC_Coef  = c(-0.2351,
                round(coef(logit_no_state)["bwc"], 4),
                round(coef(ols_model)["bwc"], 4),
                -0.4145),
  Std_Error = c(0.1788,
                round(summary(logit_no_state)$coefficients["bwc", 2], 4),
                round(summary(ols_model)$coefficients["bwc", 2], 4),
                0.2967),
  P_Value   = c(0.1886,
                round(summary(logit_no_state)$coefficients["bwc", 4], 4),
                round(summary(ols_model)$coefficients["bwc", 4], 4),
                0.1624),
  Significance = ""
) %>%
  mutate(Significance = case_when(
    P_Value < 0.001 ~ "***",
    P_Value < 0.01  ~ "**",
    P_Value < 0.05  ~ "*",
    P_Value < 0.1   ~ ".",
    TRUE            ~ ""
  ))

kable(comparison_table,
      caption = "Table 5: Robustness Check - BWC Coefficient Across Models",
      format = "simple",
      col.names = c("Model", "BWC Coef.", "Std. Err.", "p-value", "Sig."))

# IV Second Stage (Manual 2SLS)
