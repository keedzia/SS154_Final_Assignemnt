# Load Libraries
library(dplyr)
library(AER)
library(lmtest)
library(kableExtra)

# Load Data
df <- SS154_Police_Force_Dataset_IV_update_

# Logistic Regression - Clean and Encode Variables
df_clean <- df %>%
  mutate(
    lethal_response = ifelse(manner_of_death == "shot", 1, 0),
    bwc            = as.factor(body_camera),
    year           = as.factor(as.numeric(format(as.Date(date), "%Y"))),
    race           = as.factor(race),
    gender         = as.factor(gender),
    mental_illness = as.factor(signs_of_mental_illness),
    threat         = as.factor(threat_level),
    fleeing        = as.factor(flee),
    is_armed       = as.factor(armed),
    location       = as.factor(state)
  ) %>%
  filter(!is.na(lethal_response), !is.na(bwc))

# Logistic Regression - Full Model
model <- glm(lethal_response ~ bwc + year + race + age + gender +
               mental_illness + threat + fleeing + is_armed + location,
             data = df_clean,
             family = binomial(link = "logit"))

exp(coef(model))
summary(model)

# Logistic Regression - Key Variables Table
logit_coefs <- summary(model)$coefficients

key_vars <- c("bwcTRUE",
              "year2016", "year2017", "year2018",
              "year2019", "year2020", "year2021", "year2022",
              "raceB", "raceH", "raceN", "raceO", "raceW",
              "age", "genderM", "mental_illnessTRUE",
              "threatother", "threatundetermined",
              "fleeingFoot", "fleeingNot fleeing", "fleeingOther")

logit_table <- as.data.frame(logit_coefs[key_vars, ])
logit_table$OddsRatio <- round(exp(logit_table$Estimate), 3)
logit_table <- logit_table %>%
  mutate(
    Estimate     = round(Estimate, 4),
    `Std. Error` = round(`Std. Error`, 4),
    `z value`    = round(`z value`, 3),
    `Pr(>|z|)`   = round(`Pr(>|z|)`, 4),
    Significance = case_when(
      `Pr(>|z|)` < 0.001 ~ "***",
      `Pr(>|z|)` < 0.01  ~ "**",
      `Pr(>|z|)` < 0.05  ~ "*",
      `Pr(>|z|)` < 0.1   ~ ".",
      TRUE               ~ ""
    )
  )

rownames(logit_table) <- c(
  "BWC Present",
  "Year 2016", "Year 2017", "Year 2018", "Year 2019",
  "Year 2020", "Year 2021", "Year 2022",
  "Race: Black", "Race: Hispanic", "Race: Native American",
  "Race: Other", "Race: White",
  "Age", "Gender: Male", "Signs of Mental Illness",
  "Threat Level: Other", "Threat Level: Undetermined",
  "Flee: Foot", "Flee: Not Fleeing", "Flee: Other"
)

kable(logit_table,
      caption = "Table 3: Logistic Regression Results (Key Variables)",
      format = "simple",
      col.names = c("Coef.", "Std. Err.", "z", "p-value", "Odds Ratio", "Sig."))

# IV Setup
df_iv <- df %>%
  mutate(
    lethal = as.integer(manner_of_death == "shot"),
    bwc    = as.integer(body_camera == TRUE),
    year   = as.numeric(format(as.Date(date), "%Y"))
  ) %>%
  na.omit()

# IV Regression (2SLS)
iv_model <- ivreg(lethal ~ bwc + factor(year) + factor(race) + age +
                    factor(gender) + signs_of_mental_illness +
                    factor(threat_level) + factor(flee) +
                    factor(armed) + factor(state) |
                    bwc_grant_active + factor(year) + factor(race) + age +
                    factor(gender) + signs_of_mental_illness +
                    factor(threat_level) + factor(flee) +
                    factor(armed) + factor(state),
                  data = df_iv)

summary(iv_model, diagnostics = TRUE)

# First Stage
first_stage <- lm(bwc ~ bwc_grant_active + factor(year) + factor(race) + age +
                    factor(gender) + signs_of_mental_illness +
                    factor(threat_level) + factor(flee) +
                    factor(armed) + factor(state),
                  data = df_iv)

summary(first_stage)
waldtest(first_stage)

